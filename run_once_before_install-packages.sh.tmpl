#!/usr/bin/env bash
# chezmoi run_once script — installs zsh, git, oh-my-zsh; sets default shell
# Re-running is safe: every step is guarded by a presence check.
{{ if eq .chezmoi.os "linux" -}}
set -euo pipefail

# ---------------------------------------------------------------------------
# Base packages (Debian/Ubuntu only)
# ---------------------------------------------------------------------------
PACKAGES=(zsh git curl ca-certificates)
MISSING=()
for pkg in "${PACKAGES[@]}"; do
    dpkg -s "$pkg" &>/dev/null || MISSING+=("$pkg")
done
if [ "${#MISSING[@]}" -gt 0 ]; then
    sudo apt-get update -qq
    sudo apt-get install -y "${MISSING[@]}"
fi

# ---------------------------------------------------------------------------
# oh-my-zsh
# ---------------------------------------------------------------------------
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    RUNZSH=no CHSH=no \
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

# ---------------------------------------------------------------------------
# Default shell → zsh
# ---------------------------------------------------------------------------
ZSH_PATH="$(command -v zsh)"
if [ "$(getent passwd "$USER" | cut -d: -f7)" != "$ZSH_PATH" ]; then
    sudo chsh -s "$ZSH_PATH" "$USER" || echo "chsh failed — ensure $ZSH_PATH is listed in /etc/shells"
fi
{{ end -}}
